# Rust build artifacts
target/
**/*.rs.bk
# Cargo.lock — library convention (matches the original ct-crypto-node and -wasm
# repos). Flip this if/when we add binary targets that need reproducibility.
Cargo.lock

# Node
node_modules/

# wasm-pack output (regenerated by scripts/build-wasm.sh in ct-crypto-wasm)
packages/ct-crypto-wasm/pkg/

# NAPI prebuild output (built by CI; never committed)
packages/ct-crypto-node/prebuilds/

# npm publish staging dir (built by CI)
packages/ct-crypto-node/npm-package/
packages/ct-crypto-node/npm-package.zip

# Editor / OS
.DS_Store
.idea/
.vscode/

# Nix
result
result-*
.direnv/

# Local commit-helper shell scripts (GPG-signing requires a TTY, so we
# drive `git commit` via interactive scripts kept out of source control)
commit-*.sh
release-*.sh
