# Rust build artifacts
target/
**/*.rs.bk
# Cargo.lock IS committed. This workspace produces published binary
# artifacts (NAPI .node, wasm) that consumers run, so the exact dependency graph
# must be reproducible and auditable. CI builds with `--locked`.

# Node
node_modules/

# wasm-pack output (regenerated by scripts/build-wasm.sh in ct-crypto-wasm)
packages/ct-crypto-wasm/pkg/

# NAPI prebuild output (built by CI; never committed)
packages/ct-crypto-node/prebuilds/

# Mobile native binaries (built by CI via build-mobile.yml; never committed)
packages/ct-crypto-mobile/ios/HathorCtCrypto.xcframework/
packages/ct-crypto-mobile/android/src/main/jniLibs/

# npm publish staging dirs (built by CI / release tooling)
packages/ct-crypto-node/npm-package/
packages/ct-crypto-node/npm-package.zip
.release/

# Editor / OS
.DS_Store
.idea/
.vscode/

# Nix
result
result-*
.direnv/

# Local commit/publish-helper shell scripts (GPG-signing and npm 2FA require
# a TTY, so we drive them via interactive scripts kept out of source control)
commit-*.sh
release-*.sh
publish-*.sh
push-*.sh
