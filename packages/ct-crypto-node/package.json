{
  "name": "@hathor/ct-crypto-node",
  "version": "0.0.1-shielded",
  "description": "Hathor confidential transaction cryptography — NAPI native addon for Node.js. Implements @hathor/ct-crypto-provider's IShieldedCryptoProvider via the './provider' subpath. Mobile lives in @hathor/ct-crypto-mobile.",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./provider": {
      "types": "./provider.d.ts",
      "default": "./provider.js"
    }
  },
  "napi": {
    "binaryName": "ct-crypto",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "files": [
    "index.js",
    "index.d.ts",
    "provider.js",
    "provider.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "napi build --platform --release --features napi",
    "build:debug": "napi build --platform --features napi",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "pretest": "napi build --platform --features napi",
    "test": "jest",
    "version": "napi version"
  },
  "dependencies": {
    "@hathor/ct-crypto-provider": "0.0.1-shielded"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3",
    "@types/jest": "29.5.12",
    "@types/node": "20.14.2",
    "jest": "29.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HathorNetwork/hathor-ct-crypto",
    "directory": "packages/ct-crypto-node"
  },
  "keywords": [
    "hathor",
    "confidential-transactions",
    "pedersen",
    "range-proofs",
    "secp256k1",
    "napi"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
